<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CityVisitorFinaly.MenuPage"
             Title="MenuPage">

    <!-- ✅ Grid позволяет накладывать элементы -->
    <Grid>

        <!-- Твои кнопки — БЕЗ ИЗМЕНЕНИЙ, просто внутри Grid -->
        <VerticalStackLayout>
            <Button  
                x:Name="Button1"
                Text="Регионы"
                VerticalOptions="Center" 
                HorizontalOptions="Center"
                Clicked="ButtonRegion_Clicked"/>
            <Button  
                Text="Карты"
                x:Name="Button2"
                VerticalOptions="Center" 
                HorizontalOptions="Center"
                Clicked="ButtonMaps_Clicked"/>
        </VerticalStackLayout>

        <!-- ✅ Индикатор загрузки (поверх, по центру) -->
        <ActivityIndicator 
            x:Name="loadingIndicator"
            HorizontalOptions="Center" 
            VerticalOptions="Center" 
            Color="#0066CC"
            Scale="1.5"
            IsRunning="False"
            IsVisible="False"
            InputTransparent="True"/>

    </Grid>
</ContentPage>